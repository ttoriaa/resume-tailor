# OpenAI-compatible API configuration
# If OPENAI_API_KEY is empty, app falls back to local rule-based rewriting.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model used for resume tailoring text generation
RESUME_TAILOR_MODEL=gpt-4o-mini

# Model used for OCR when JD image is uploaded
RESUME_JD_OCR_MODEL=gpt-4.1-mini

# Optional runtime configuration
RESUME_TAILOR_HOST=127.0.0.1
RESUME_TAILOR_PORT=8787
